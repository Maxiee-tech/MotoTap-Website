# Copy to functions/.env for local emulator (never commit).
# Set the API secret via: firebase functions:secrets:set CLOUDINARY_API_SECRET
# Each preset must be Signing mode: Signed in Cloudinary Dashboard.

CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_CLOUD_NAME=deoquaz6p

# One signed upload preset per category (names must match Cloudinary Dashboard)
CLOUDINARY_PRESET_PROFILE_PHOTOS=mototap_profile_photos
CLOUDINARY_PRESET_SIGNUP_DOCUMENTS=mototap_signup_documents
CLOUDINARY_PRESET_VEHICLES=mototap_vehicles
CLOUDINARY_PRESET_USER_UPLOADS=mototap_user_uploads
