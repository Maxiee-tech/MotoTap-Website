rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdminUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.get('isAdmin', false) == true;
    }

    function validUserRole(role) {
      return role in ['mechanic', 'driver', 'MECHANIC', 'DRIVER'];
    }

    function validExperienceYears(value) {
      return value in ['0-1', '1-3', '3-5', '5-10', '10+'];
    }

    function validOnboardingFields(data) {
      return (!('onboardingStep' in data) || (data.onboardingStep is int && data.onboardingStep >= 1 && data.onboardingStep <= 3))
        && (!('onboardingComplete' in data) || data.onboardingComplete is bool)
        && (!('status' in data) || data.status in ['PENDING', 'APPROVED', 'REJECTED'])
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 32))
        && (!('profilePhotoUrl' in data) || (data.profilePhotoUrl is string && data.profilePhotoUrl.size() <= 2048))
        && (!('idPhotoUrl' in data) || (data.idPhotoUrl is string && data.idPhotoUrl.size() <= 2048))
        && (!('idNumber' in data) || (data.idNumber is string && data.idNumber.size() <= 64))
        && (!('vehicleType' in data) || (data.vehicleType is string && data.vehicleType.size() <= 64))
        && (!('vehicleModel' in data) || (data.vehicleModel is string && data.vehicleModel.size() <= 64))
        && (!('numberPlate' in data) || (data.numberPlate is string && data.numberPlate.size() <= 32))
        && (!('vehiclePhotoUrl' in data) || (data.vehiclePhotoUrl is string && data.vehiclePhotoUrl.size() <= 2048))
        && (!('certificateNumber' in data) || (data.certificateNumber is string && data.certificateNumber.size() <= 64))
        && (!('certificatePhotoUrl' in data) || (data.certificatePhotoUrl is string && data.certificatePhotoUrl.size() <= 2048))
        && (!('institutionName' in data) || (data.institutionName is string && data.institutionName.size() <= 120))
        && (!('experienceYears' in data) || (data.experienceYears is string && validExperienceYears(data.experienceYears)))
        && (!('latitude' in data) || (data.latitude is number && data.latitude >= -90 && data.latitude <= 90))
        && (!('longitude' in data) || (data.longitude is number && data.longitude >= -180 && data.longitude <= 180))
        && (!('address' in data) || (data.address is string && data.address.size() <= 300))
        && (!('garagePhotos' in data) || (data.garagePhotos is list && data.garagePhotos.size() <= 5))
        && (!('vehicles' in data) || (data.vehicles is list && data.vehicles.size() <= 20))
        && (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5))
        && (!('reviewCount' in data) || (data.reviewCount is int && data.reviewCount >= 0));
    }

    function validJobStatus(status) {
      return status in [
        'REQUESTED',
        'MATCHING',
        'ASSIGNED',
        'IN_PROGRESS',
        'COMPLETED',
        'PAID',
        'CLOSED'
      ];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && validUserRole(request.resource.data.role)
        && request.resource.data.get('isAdmin', false) == false
        && validOnboardingFields(request.resource.data);
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && (!('skills' in request.resource.data) || request.resource.data.skills is list)
        && (!('availableServices' in request.resource.data)
          || request.resource.data.availableServices is list)
        && (!('servicePrices' in request.resource.data)
          || (request.resource.data.servicePrices is map
            && request.resource.data.servicePrices.size() <= 200))
        && (!('phoneNumber' in request.resource.data)
          || (request.resource.data.phoneNumber is string
            && request.resource.data.phoneNumber.size() <= 32))
        && validOnboardingFields(request.resource.data);
      allow delete: if isOwner(userId);

      match /chatPartners/{partnerId} {
        function isChatPartnerTypingUpdate() {
          return signedIn()
            && (request.auth.uid == userId || request.auth.uid == partnerId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['partnerIsTyping', 'partnerTypingAtMillis', 'partnerId']);
        }

        function validChatPartnerWrite() {
          return request.resource.data.partnerId == partnerId
            && (!('lastMessageText' in request.resource.data)
              || (request.resource.data.lastMessageText is string
                && request.resource.data.lastMessageText.size() <= 500))
            && (!('partnerName' in request.resource.data)
              || (request.resource.data.partnerName is string
                && request.resource.data.partnerName.size() <= 120));
        }

        allow read: if signedIn() && request.auth.uid == userId;
        allow create, update: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == partnerId)
          && (validChatPartnerWrite() || isChatPartnerTypingUpdate());
        allow delete: if false;
      }
    }

    match /serviceCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdminUser();
    }

    match /jobs/{jobId} {
      function isJobDriver() {
        return signedIn() && resource.data.driverId == request.auth.uid;
      }

      function isJobMechanic() {
        return signedIn() && resource.data.mechanicId == request.auth.uid;
      }

      function isOpenJob() {
        return resource.data.status == 'REQUESTED'
          && (resource.data.mechanicId == null || !('mechanicId' in resource.data));
      }

      allow read: if signedIn()
        && (resource.data.driverId == request.auth.uid
          || resource.data.mechanicId == request.auth.uid
          || isOpenJob());

      allow create: if signedIn()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.status == 'REQUESTED'
        && validJobStatus(request.resource.data.status)
        && request.resource.data.serviceName is string
        && request.resource.data.serviceName.size() > 0
        && request.resource.data.serviceName.size() <= 120
        && request.resource.data.createdAtMillis is int
        && (!('description' in request.resource.data)
          || (request.resource.data.description is string
            && request.resource.data.description.size() <= 1000))
        && (!('locationLabel' in request.resource.data)
          || (request.resource.data.locationLabel is string
            && request.resource.data.locationLabel.size() <= 200))
        && (!('price' in request.resource.data)
          || (request.resource.data.price is number && request.resource.data.price >= 0));

      function isCompletedJob() {
        return resource.data.status in ['COMPLETED', 'PAID', 'CLOSED'];
      }

      function isDriverReviewUpdate() {
        return isJobDriver()
          && isCompletedJob()
          && resource.data.mechanicId != null
          && !('driverReviewRating' in resource.data)
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == resource.data.mechanicId
          && request.resource.data.status == resource.data.status
          && request.resource.data.driverReviewRating is int
          && request.resource.data.driverReviewRating >= 1
          && request.resource.data.driverReviewRating <= 5
          && request.resource.data.driverReviewComment is string
          && request.resource.data.driverReviewComment.size() > 0
          && request.resource.data.driverReviewComment.size() <= 150
          && request.resource.data.driverReviewedAtMillis is int;
      }

      allow update: if signedIn() && (
        isDriverReviewUpdate()
        || (isJobDriver()
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == resource.data.mechanicId
          && validJobStatus(request.resource.data.status))
        || (isJobMechanic()
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == resource.data.mechanicId
          && validJobStatus(request.resource.data.status))
        || (isOpenJob()
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == request.auth.uid
          && request.resource.data.status == 'ASSIGNED'
          && resource.data.status == 'REQUESTED')
      );

      allow delete: if isJobDriver();

      match /messages/{messageId} {
        allow read, create: if signedIn()
          && (get(/databases/$(database)/documents/jobs/$(jobId)).data.driverId == request.auth.uid
            || get(/databases/$(database)/documents/jobs/$(jobId)).data.mechanicId == request.auth.uid);
      }
    }

    match /jobRequests/{requestId} {
      function isRequestDriver() {
        return signedIn() && resource.data.driverId == request.auth.uid;
      }

      function isRequestMechanic() {
        return signedIn() && resource.data.mechanicId == request.auth.uid;
      }

      function isOpenRequest() {
        return resource.data.status == 'REQUESTED'
          && (resource.data.mechanicId == null || !('mechanicId' in resource.data));
      }

      allow read: if signedIn()
        && (resource.data.driverId == request.auth.uid
          || resource.data.mechanicId == request.auth.uid
          || isOpenRequest());

      allow create: if signedIn()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.status == 'REQUESTED'
        && validJobStatus(request.resource.data.status)
        && request.resource.data.createdAtMillis is int
        && (!('serviceName' in request.resource.data)
          || (request.resource.data.serviceName is string
            && request.resource.data.serviceName.size() <= 120))
        && (!('description' in request.resource.data)
          || (request.resource.data.description is string
            && request.resource.data.description.size() <= 1000))
        && (!('locationLabel' in request.resource.data)
          || (request.resource.data.locationLabel is string
            && request.resource.data.locationLabel.size() <= 200));

      allow update: if signedIn() && (
        (isRequestDriver()
          && request.resource.data.driverId == resource.data.driverId)
        || (isRequestMechanic()
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == resource.data.mechanicId)
        || (isOpenRequest()
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.mechanicId == request.auth.uid
          && request.resource.data.status == 'ASSIGNED'
          && resource.data.status == 'REQUESTED')
      );

      allow delete: if isRequestDriver();
    }

    match /chats/{roomId} {
      function chatRoomPath() {
        return /databases/$(database)/documents/chats/$(roomId);
      }
      function chatRoomExists() {
        return exists(chatRoomPath());
      }
      function chatRoomParticipants() {
        return chatRoomExists()
          ? get(chatRoomPath()).data.get('participants', [])
          : [];
      }
      function isChatParticipant() {
        return signedIn()
          && request.auth.uid in chatRoomParticipants();
      }
      function isIncomingChatParticipant() {
        return signedIn()
          && request.auth.uid in request.resource.data.get('participants', []);
      }
      function canBootstrapChatRoom() {
        return signedIn()
          && isIncomingChatParticipant()
          && chatRoomParticipants().size() == 0;
      }
      function uidInRoomId() {
        return signedIn()
          && roomId.matches('.*' + request.auth.uid + '.*');
      }

      allow read: if signedIn()
        && (isChatParticipant() || chatRoomParticipants().size() == 0 || uidInRoomId());

      function isTypingStatusUpdate() {
        return uidInRoomId()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'typingStatus',
              'lastActive',
              'lastActiveMillis',
              'participants',
              'participantNames',
              'lastMessageText',
              'lastMessageSenderId',
              'lastMessageMillis'
            ])
          && (!('lastMessageText' in request.resource.data)
            || (request.resource.data.lastMessageText is string
              && request.resource.data.lastMessageText.size() <= 500));
      }

      allow create: if isIncomingChatParticipant();
      allow update: if isChatParticipant() || canBootstrapChatRoom()
        || (uidInRoomId() && isIncomingChatParticipant())
        || isTypingStatusUpdate();

      match /messages/{messageId} {
        allow read: if signedIn()
          && (isChatParticipant() || chatRoomParticipants().size() == 0 || uidInRoomId());
        allow create: if signedIn()
          && (isChatParticipant() || chatRoomParticipants().size() == 0 || uidInRoomId())
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 200
          && request.resource.data.timestampMillis is int
          && request.resource.data.read is bool;
        allow update: if signedIn()
          && isChatParticipant()
          && request.auth.uid != resource.data.senderId
          && resource.data.read == false
          && request.resource.data.read == true
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.text == resource.data.text
          && request.resource.data.timestampMillis == resource.data.timestampMillis;
        allow delete: if false;
      }
    }

    match /chatMessages/{messageId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.senderId
          || request.auth.uid in resource.data.get('participantIds', [])
          || (resource.data.get('conversationId', '').matches('.*' + request.auth.uid + '.*')));
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 200
        && request.resource.data.timestampMillis is int
        && (request.auth.uid in request.resource.data.get('participantIds', [])
          || request.resource.data.get('conversationId', '').matches('.*' + request.auth.uid + '.*'));
      allow update, delete: if false;
    }

    match /homeReviews/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() <= 150
        && request.resource.data.reviewedAtMillis is int
        && request.resource.data.createdAtMillis is int
        && request.resource.data.updatedAtMillis is int;
      allow delete: if false;
    }

    match /homeReviewRateLimit/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.writeLogMillis is list
        && request.resource.data.writeLogMillis.size() <= 10;
      allow delete: if false;
    }

    match /website_messages/{messageId} {
      allow read: if false;
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() <= 40
        && (!('email' in request.resource.data)
          || (request.resource.data.email is string
            && request.resource.data.email.size() <= 254));
    }
  }
}
