# Copy to .env for local dev and Docker builds (never commit .env).

# Firebase web config (public in the client bundle; restrict in Firebase Console).
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Google Maps JavaScript API — website only (separate from Android key).
VITE_GOOGLE_MAPS_API_KEY=your-browser-maps-key-here

# Cloudinary — Option B (unsigned, Spark plan — no Cloud Functions required)
# Presets must be Signing mode: UNSIGNED in Cloudinary Dashboard.
# NEVER add CLOUDINARY_API_SECRET here.
VITE_CLOUDINARY_UPLOAD_MODE=unsigned
VITE_CLOUDINARY_CLOUD_NAME=deoquaz6p

# Preset names — must match Cloudinary Dashboard exactly (Unsigned mode)
VITE_CLOUDINARY_PRESET_PROFILE_PHOTOS=profile_photos
VITE_CLOUDINARY_PRESET_SIGNUP_DOCUMENTS=signup_documents
VITE_CLOUDINARY_PRESET_VEHICLES=vehicles
VITE_CLOUDINARY_PRESET_USER_UPLOADS=user_uploads

# Switch to signed uploads after upgrading to Blaze + deploying Functions:
# VITE_CLOUDINARY_UPLOAD_MODE=signed

# Development
VITE_DEV_SERVER_PORT=5173
