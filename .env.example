# Copy to .env for local dev and Docker builds (never commit .env).

# Firebase web config (public in the client bundle; restrict in Firebase Console).
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Google Maps JavaScript API — website only (separate from Android key).
# Cloud Console → Credentials → HTTP referrers for every live origin:
# https://mototap-447fe.web.app/*, https://mototap.co.ke/*, http://localhost:5173/*
# API restrictions: Maps JavaScript API only.
VITE_GOOGLE_MAPS_API_KEY=your-browser-maps-key-here

# Development
VITE_DEV_SERVER_PORT=5173
