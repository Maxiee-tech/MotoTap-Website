{
  "name": "mototap_web",
  "version": "1.0.0",
  "description": "This is a simple static website that uses your existing Firebase backend configuration.",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && NODE_OPTIONS='--dns-result-order=ipv4first' firebase deploy --only hosting,firestore:rules,firestore:indexes",
    "deploy:hosting": "npm run build && NODE_OPTIONS='--dns-result-order=ipv4first' firebase deploy --only hosting",
    "deploy:rules": "NODE_OPTIONS='--dns-result-order=ipv4first' firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "NODE_OPTIONS='--dns-result-order=ipv4first' firebase deploy --only functions",
    "deploy:blaze": "npm run build && NODE_OPTIONS='--dns-result-order=ipv4first' firebase deploy --only hosting,firestore:rules,firestore:indexes,functions",
    "backfill:public-profiles": "node scripts/backfill-public-profiles.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "firebase": "^12.12.1"
  },
  "devDependencies": {
    "firebase-tools": "^15.19.1",
    "terser": "^5.48.0",
    "vite": "^5.0.0"
  }
}
